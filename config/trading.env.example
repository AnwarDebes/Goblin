# EXAMPLE template - copy to trading.env; real secrets go in .secrets.env (gitignored).

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=   # set in config/.secrets.env
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=goblin
POSTGRES_USER=goblin
POSTGRES_PASSWORD=   # set in config/.secrets.env
TRADING_MODE=paper
INITIAL_CAPITAL=10000
MAX_POSITION_SIZE=0.1
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.05
CRYPTOPANIC_API_KEY=   # set in config/.secrets.env
WHALE_ALERT_API_KEY=   # set in config/.secrets.env
OPENAI_API_KEY=   # set in config/.secrets.env
PAPER_MODE=true
# rehearsal first: build+validate real orders, place nothing until flipped
LIVE_DRY_RUN=true
# capital preservation kill switch: no new entries below this free-USDT level
BALANCE_FLOOR_USD=0
# 2026-05-27 horizon pivot: restrict to deep-liquidity majors. The thin-altcoin pumps that drove past "wins" (ATR, AVL, WOD) are noise at the horizon timescale.
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,AVAX/USDT,SUI/USDT
STARTING_CAPITAL=1000.0
MAX_POSITION_PCT=0.50
MIN_POSITION_USD=1.50
MAX_DAILY_LOSS_PCT=0.10
# MAX_OPEN_POSITIONS removed - system decides dynamically based on capital
# 2026-06-09: 180s cooldown was the binding rate limit (one entry per ~173s, max
# churn). 30 min hard-caps fee drag; best in-sample counterfactual filter.
MIN_TIME_BETWEEN_TRADES=1800
# 2026-05-27 horizon pivot: 15-min holds need targets sized for the horizon.
# Round-trip taker fee ~0.20%; target must clear that with margin.
PROFIT_TARGET_PCT=0.010
MAX_TRADE_LOSS_PCT=0.012
MAX_HOLD_TIME_MINUTES=120
DB_ENABLED=true
WS_ENABLED=true
WS_TOP_SYMBOLS=500
REST_POLL_INTERVAL=1.0
FEATURE_COMPUTE_INTERVAL=2.0
# Horizon pivot: 30-sec inference is plenty for 15-min forecasts.
# Reduces GPU load and removes noise that previously fed AI exit pressure.
INFERENCE_INTERVAL=30.0
MAX_ACTIVE_PAIRS=200
INFERENCE_WORKERS=80
MODEL_DIR=/home/coder/Goblin/shared/models
# 2026-05-25 phase 2: re-enabled broader universe to test asymmetry-fixed strategy
# on the same universe as the original baseline. Majors-only ratio was 0.56 over 20 trades
# (almost same as 0.60 baseline). Hypothesis: my hard-floor + patience-exit fixes
# work better on the broader universe where occasional altcoin momentum wins balance
# small fee-eating losses.
# TRADING_PAIRS_FILE=/home/coder/Goblin/config/trading_pairs.txt
DB_PERSIST_INTERVAL=60
FEATURE_STORE_URL=http://localhost:8007
MARKET_DATA_URL=http://localhost:8001
PREDICTION_URL=http://localhost:8002
EXECUTOR_URL=http://localhost:8005
POSITION_URL=http://localhost:8006
SIGNAL_URL=http://localhost:8003
RISK_URL=http://localhost:8004
API_GATEWAY_URL=http://localhost:8080
CRYPTOPANIC_INTERVAL=900
REDDIT_INTERVAL=600
FEAR_GREED_INTERVAL=3600
GOOGLE_TRENDS_INTERVAL=14400
SOCIAL_VOLUME_INTERVAL=900
WHALE_TRACKER_INTERVAL=300
EXCHANGE_METRICS_INTERVAL=60
SENTIMENT_WINDOW_HOURS=24
FEATURE_TTL=8
TCN_HIDDEN_CHANNELS=256
TCN_BATCH_SIZE=4096
TCN_EPOCHS_PER_CYCLE=20
XGB_BOOST_ROUNDS_PER_CYCLE=500
XGB_MAX_DEPTH=10
TRAIN_INTERVAL_MINUTES=1
TRAINING_DAYS=90
DB_POOL_MAX_SIZE=40
KELLY_MODE=half
SMART_STOP_ENABLED=true
# 2026-06-09 high-conviction retune: 12h run = 125 round trips, 33.6% win rate,
# -$18.36 net of which $8.90 was fees. Entry gates passed near-continuously at
# 0.55; only the top conviction tail can clear the 0.1% round-trip fee.
CONFIDENCE_THRESHOLD=0.75
# 2026-05-27 mid-pivot diagnostic: 6 of 7 ai_sell_reversal losses fired at
# confidence 0.25-0.26 on majors where last_directions was mostly buys.
# Entry required 0.55 but exit accepted 0.20 - asymmetric whipsaw.
# Symmetric threshold forces real conviction on both sides.
AI_EXIT_CONFIDENCE=0.55
PORTFOLIO_CASH_RESERVE_PCT=0.20
PORTFOLIO_MAX_POSITION_PCT=0.50

# 2026-06-09 high-conviction retune (new knobs, were code defaults)
# Wider ranker window: compare more candidates per slot before picking best
SIGNAL_BUFFER_WINDOW_S=30
# Halt the day at -2% (default was -3%) before fees+losses compound
DAILY_DRAWDOWN_KILL_PCT=0.02
# Re-entering a recent loser must clear 0.75+0.20 confidence - effectively never
LOSS_COOLDOWN_CONF_BOOST=0.20
GRADIENT_ACCUMULATION_STEPS=2
