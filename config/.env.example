# ===========================================
# MangoCoco Configuration Template
# ===========================================
#
# IMPORTANT: Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git!
#
# To use this file:
#   cp config/.env.example config/.env
#   nano config/.env  # Edit with your actual credentials
#

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# ===========================================
# MEXC CREDENTIALS - REQUIRED!
# ===========================================
# Get your API credentials from MEXC:
# 1. Login to MEXC (https://www.mexc.com)
# 2. Go to API Management
# 3. Create new API key with trading permissions
# 4. Add your server IP to the whitelist
#
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here

# ===========================================
# DATABASE
# ===========================================
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=mangococo
POSTGRES_USER=mangococo
POSTGRES_PASSWORD=ChangeMeToSecurePassword123!

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ChangeMeToSecureRedisPassword123!

# ===========================================
# TRADING CONFIGURATION
# ===========================================
# Trading pairs to monitor (comma-separated)
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT

# Starting capital in USDT
STARTING_CAPITAL=2.89

# Risk Limits
MAX_POSITION_PCT=0.50          # Max 50% of capital per position
MIN_POSITION_USD=0.50          # Minimum trade size in USD
MAX_DAILY_LOSS_PCT=0.20        # Stop trading if daily loss exceeds 20%
MAX_TRADE_LOSS_PCT=0.05        # Max loss per trade (5%)
MAX_OPEN_POSITIONS=2           # Maximum concurrent positions
MIN_TIME_BETWEEN_TRADES=60     # Minimum seconds between trades

# ===========================================
# ML CONFIGURATION
# ===========================================
# Machine Learning Model Settings
SEQUENCE_LENGTH=60              # Number of historical data points for prediction
PREDICTION_HORIZON=5            # How many minutes ahead to predict
CONFIDENCE_THRESHOLD=0.6        # Minimum confidence to generate signal (0-1)
USE_GPU=false                   # Set to true if you have NVIDIA GPU

# ===========================================
# ADVANCED SETTINGS (Optional)
# ===========================================
# Only modify these if you know what you're doing

# Model Update Frequency
# MODEL_RETRAIN_INTERVAL=86400  # Retrain model every 24 hours (seconds)

# Feature Engineering
# TECHNICAL_INDICATORS=RSI,MACD,BB,EMA,VOLUME

# Risk Management
# STOP_LOSS_PCT=0.02            # Automatic stop loss at 2%
# TAKE_PROFIT_PCT=0.05          # Automatic take profit at 5%

# Monitoring
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id
# ALERT_ON_TRADE=true
# ALERT_ON_ERROR=true
